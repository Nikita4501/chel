<Page x:Class="chel.CheckoutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Checkout">
    <StackPanel Margin="10">
        <TextBlock Text="Оформление билета" FontSize="20" FontWeight="Bold" />
        <TextBlock x:Name="InfoText" Margin="0,8,0,8" TextWrapping="Wrap"/>
        <ItemsControl x:Name="SelectedSeatsList"/>
        <TextBlock x:Name="TotalText" FontWeight="Bold" Margin="0,8,0,8"/>
        <StackPanel Orientation="Horizontal">
            <Button Content="Подтвердить" Click="Confirm_Click" Margin="6"/>
            <Button Content="Отмена" Click="Cancel_Click" Margin="6"/>
            <Button Content="На главную"
        Click="Home_Click"
        HorizontalAlignment="Left"
        Margin="10"/>

        </StackPanel>
    </StackPanel>
</Page>
