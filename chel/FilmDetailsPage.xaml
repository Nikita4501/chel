<Page x:Class="chel.FilmDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="FilmDetails">
    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal">
            <Image Width="240" Height="340" Source="{Binding CoverPath}" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Width="500" Margin="0,8,0,0"/>
                <TextBlock Text="{Binding Rating, StringFormat='Рейтинг: {0}'}" Margin="0,6,0,0"/>
                <TextBlock Text="Жанры:" FontWeight="Bold" Margin="0,8,0,0"/>
                <ItemsControl x:Name="GenresList" />
            </StackPanel>
        </StackPanel>

        <TextBlock Text="Сеансы" FontSize="16" FontWeight="Bold" Margin="0,12,0,6"/>
        <ItemsControl x:Name="SessionsList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#CCC" BorderThickness="1" Margin="4" Padding="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StartDateTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="150"/>
                            <!-- Теперь используем HallName -->
                            <TextBlock Text="{Binding HallName}" Width="120"/>
                            <TextBlock Text="{Binding Price, StringFormat='Цена: {0}'}" Width="100"/>
                            <Button Content="Выбрать" Tag="{Binding SessionId}" Click="OpenSession_Click"/>

                        </StackPanel>
                    </Border>
                    
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="На главную" Click="Home_Click" HorizontalAlignment="Left" Margin="10"/>
    </StackPanel>
</Page>
