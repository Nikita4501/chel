<Page x:Class="chel.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Profile">

    <StackPanel Margin="20">

        <TextBlock Text="Личный кабинет"
                   FontSize="22"
                   FontWeight="Bold"/>

        <TextBlock x:Name="NameText"
                   Margin="0,5,0,15"/>

        <TextBlock Text="Билеты"
                   FontWeight="Bold"/>

        <ListBox x:Name="TicketsList" Margin="0,10,0,20">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,5">
                        <TextBlock Text="{Binding MovieTitle}"/>
                        <TextBlock Text="{Binding SessionInfo}"/>
                        <TextBlock Text="{Binding SeatInfo}"/>
                        <TextBlock Text="{Binding PriceInfo}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal">
            <Button Content="На главную"
                    Click="Home_Click"
                    Margin="0,0,10,0"/>

            <Button Content="Выйти"
                    Click="Logout_Click"/>
        </StackPanel>

    </StackPanel>
</Page>
