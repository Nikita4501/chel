<Window x:Class="chel.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Личный кабинет" Height="400" Width="500">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Личный кабинет" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Здесь можно реализовать авторизацию, список заказов/закладок и т.д." TextWrapping="Wrap"/>
            <Button Content="Закрыть" Width="100" Margin="0,10,0,0" HorizontalAlignment="Left" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
